{
  "name": "next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "commit": "cz",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-query-devtools": "^5.100.0",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "nprogress": "^0.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "cz-git": {
    "maxSubjectLength": 100,
    "allowBreakingChanges": [
      "feat",
      "fix",
      "refactor"
    ],
    "types": [
      {
        "value": "feat",
        "name": "feat:     Add a new feature"
      },
      {
        "value": "fix",
        "name": "fix:      Fix a bug"
      },
      {
        "value": "refactor",
        "name": "refactor: Refactor code"
      },
      {
        "value": "perf",
        "name": "perf:     Improve performance"
      },
      {
        "value": "docs",
        "name": "docs:     Update documentation"
      },
      {
        "value": "test",
        "name": "test:     Add or update tests"
      },
      {
        "value": "build",
        "name": "build:    Build system or dependency changes"
      },
      {
        "value": "ci",
        "name": "ci:       CI configuration updates"
      },
      {
        "value": "chore",
        "name": "chore:    Other maintenance tasks"
      }
    ]
  }
}
